{
  "name": "xsnippet-web",
  "version": "1.0.0",
  "description": "Web UI for XSnippet code sharing service",
  "author": "The XSnippet Team <dev@xsnippet.org>",
  "license": "MIT",
  "homepage": "https://github.com/xsnippet/xsnippet-web",
  "bugs": {
    "url": "https://github.com/xsnippet/xsnippet-web/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xsnippet/xsnippet-web.git"
  },
  "keywords": [
    "xsnippet",
    "ui",
    "code",
    "sharing"
  ],
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/tests/testSetup.js"
    ],
    "collectCoverage": true,
    "coverageDirectory": "./coverage",
    "moduleNameMapper": {
      "^.+\\.(css|styl)$": "identity-obj-proxy",
      "^.+\\.(svg|jpg)$": "<rootDir>/tests/__mocks__/fileMock.js"
    },
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "dependencies": {
    "ace-builds": "^1.43.6",
    "joi": "^18.0.2",
    "jotai": "^2.17.1",
    "parse-link-header": "^2.0.0",
    "process": "^0.11.10",
    "querystring": "^0.2.1",
    "querystring-es3": "^0.2.1",
    "react": "^19.2.4",
    "react-ace": "^14.0.1",
    "react-custom-scrollbars": "^4.2.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "react-tag-input": "^6.10.6",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.28.6",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/parse-link-header": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "html-webpack-plugin": "^5.6.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.10.0",
    "stylus": "^0.64.0",
    "stylus-loader": "^8.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "scripts": {
    "lint": "eslint .",
    "build": "webpack --mode production",
    "start": "webpack serve --mode development --open",
    "test": "jest --coverage",
    "devenv-start": "API_PROXY_TARGET=\"http://localhost:8000\" WEB_BACKEND_PROXY_TARGET=\"http://localhost:8001\" npm start",
    "devenv-up": "docker-compose -f devenv/docker-compose.yml up"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "private": true
}
