{
  "name": "xsnippet-web",
  "version": "1.0.0",
  "description": "Web UI for XSnippet code sharing service",
  "author": "The XSnippet Team <dev@xsnippet.org>",
  "license": "MIT",
  "homepage": "https://github.com/xsnippet/xsnippet-web",
  "bugs": {
    "url": "https://github.com/xsnippet/xsnippet-web/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xsnippet/xsnippet-web.git"
  },
  "keywords": [
    "xsnippet",
    "ui",
    "code",
    "sharing"
  ],
  "jest": {
    "setupFilesAfterEnv": [
      "./tests/testSetup.js"
    ],
    "collectCoverage": true,
    "coverageDirectory": "./coverage",
    "moduleNameMapper": {
      "^.+\\.(css|styl|svg|jpg)$": "identity-obj-proxy"
    },
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "ts-jest"
    }
  },
  "dependencies": {
    "brace": "^0.11.0",
    "joi": "^17.13.3",
    "parse-link-header": "^2.0.0",
    "querystring-es3": "^0.2.1",
    "react": "^18.3.1",
    "react-ace": "^10.1.0",
    "react-custom-scrollbars": "^4.2.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-tag-input": "^6.10.6",
    "recoil": "^0.7.7",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-proposal-class-properties": "^7.0.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.0.0",
    "@babel/plugin-syntax-dynamic-import": "^7.0.0",
    "@babel/plugin-transform-runtime": "^7.26.2",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@eslint/js": "^9.29.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.5.14",
    "@types/parse-link-header": "^1.0.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "babel-core": "^7.0.0-bridge.0",
    "babel-loader": "^9.2.1",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "file-loader": "^6.2.0",
    "glob": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.2",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "stylus": "^0.54.5",
    "stylus-loader": "^8.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  },
  "scripts": {
    "lint": "eslint --ext ts,tsx src/",
    "build": "webpack --mode production",
    "start": "webpack-dev-server --mode development --open",
    "test": "jest --coverage",
    "devenv-start": "API_BASE_URI=\"http://localhost:8080/_api\" RAW_SNIPPET_URI_FORMAT=\"http://localhost:8080/_web-backend/snippets/%s/raw\" npm start",
    "devenv-up": "docker-compose -f devenv/docker-compose.yml up"
  },
  "private": true
}
